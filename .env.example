# Copy to .env.local for local dev. In production these are set as Azure App
# Service application settings (not committed).

# Shared secret for the machine-to-machine email-in receipt ingest endpoint
# (POST /api/receipts/ingest, sent in the `x-ingest-secret` header by the Power
# Automate mailbox flow). Requests without a matching value are rejected 401.
INGEST_SHARED_SECRET=replace-with-a-long-random-secret

# SMTP relay used to bounce receipts from unrecognized senders (Nodemailer).
# Optional in local dev: if SMTP_HOST is unset, bounces are logged, not sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
INGEST_BOUNCE_FROM="OHI Expense Hub <noreply@ohi.example.com>"
