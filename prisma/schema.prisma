// Prisma schema for OHI Expense Hub.
//
// The app currently runs on the in-memory mock layer (src/lib/data), which is
// written to mirror this eventual persisted schema. This file scaffolds the
// SQL Server data model; ReportChangeLog is the audit trail backing the
// "Change History" / "Change Log" features. User and ExpenseReport are included
// here because ReportChangeLog relates to them — additional domain models
// (ExpenseLineItem, Receipt, etc.) can be filled in as persistence lands.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUBMITTER
  APPROVER
  ADMIN
  ACCOUNTING
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  ACCOUNTING_REVIEW
  EXECUTIVE_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum ReportChangeType {
  STATUS
  AMOUNT
  LINE_ITEM
  FIELD
  OTHER
}

/// How a receipt entered the system.
enum ReceiptSource {
  UPLOAD
  CAMERA
  EMAIL
}

model User {
  id          String   @id @default(cuid())
  // Null until the person's first Azure AD login, which matches them by email
  // and fills this in.
  azureAdId   String?  @unique
  email       String   @unique
  name        String
  department  String
  role        UserRole
  // Soft-delete flag: inactive users can no longer sign in or be selected, but
  // their historical reports and approval history remain intact.
  isActive    Boolean  @default(true)
  // If 0, every report goes through the full approver chain. If > 0, reports
  // below this amount skip Approvers #2/#3 and go straight to the Accounting +
  // Executive groups.
  fastTrackThreshold Decimal @default(0) @db.Decimal(18, 2)
  managerId   String?
  manager     User?    @relation("UserManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reports     User[]   @relation("UserManager")

  approvalGroupMemberships ApprovalGroupMember[]

  // Per-user approval chain (up to 3 steps). Independent of managerId: an
  // approver need not be the user's manager. Each is a distinct self-relation so
  // Prisma can disambiguate the multiple User -> User links.
  approver1Id String?
  approver1   User?    @relation("UserApprover1", fields: [approver1Id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver2Id String?
  approver2   User?    @relation("UserApprover2", fields: [approver2Id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver3Id String?
  approver3   User?    @relation("UserApprover3", fields: [approver3Id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // Back-relations: users who name this user as a given approver step.
  approverFor1 User[]  @relation("UserApprover1")
  approverFor2 User[]  @relation("UserApprover2")
  approverFor3 User[]  @relation("UserApprover3")

  submittedReports ExpenseReport[]   @relation("ReportSubmitter")
  paidReports      ExpenseReport[]   @relation("ReportPayee")
  reportChanges    ReportChangeLog[] @relation("ChangeAuthor")
  ownedReceipts    Receipt[]         @relation("ReceiptOwner")
  uploadedReceipts Receipt[]         @relation("ReceiptUploader")
}

model Receipt {
  id           String    @id @default(cuid())
  // The gallery owner this receipt belongs to.
  userId       String
  owner        User      @relation("ReceiptOwner", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // Who actually uploaded it: a delegate, or the owner for self-uploads.
  // Null for system ingestion (e.g. an emailed-in receipt has no app user).
  uploadedById String?
  uploadedBy   User?     @relation("ReceiptUploader", fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // How the receipt entered the system (upload, camera capture, or email-in).
  source       ReceiptSource @default(UPLOAD)
  imageUrl     String    @db.NVarChar(Max)
  merchantName String?   @db.NVarChar(200)
  merchantDate DateTime?
  totalAmount  Decimal?  @db.Decimal(12, 2)
  taxAmount    Decimal?  @db.Decimal(12, 2)
  isAttached   Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([uploadedById])
}

/// A mandatory approval group (Accounting Approval / Executive Approval). Reports
/// route through both groups after the per-user approver chain. Seeded with two
/// rows ("ACCOUNTING", "EXECUTIVE") that cannot be deleted or renamed in the UI.
model ApprovalGroup {
  id        String                @id @default(cuid())
  key       String                @unique @db.NVarChar(50)
  name      String                @db.NVarChar(100)
  createdAt DateTime              @default(now())
  members   ApprovalGroupMember[]
}

/// Membership of a user in an approval group (M2M). Any active member of the
/// group can approve/reject/send-back a report at that group's step.
model ApprovalGroupMember {
  id        String        @id @default(cuid())
  groupId   String
  group     ApprovalGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())

  @@unique([groupId, userId])
}

/// Expense category with its general-ledger coding. SUBMITTER / APPROVER see
/// only displayName; ACCOUNTING / ADMIN also see glCode + glName.
model ExpenseType {
  id          String  @id @default(cuid())
  displayName String  @db.NVarChar(200)
  // GL (general-ledger) code, e.g. "MR5100501000".
  glCode      String  @db.NVarChar(30)
  // GL name / description, e.g. "Business Travel".
  glName      String  @db.NVarChar(255)
  isMileage   Boolean @default(false)
}

model ExpenseReport {
  id           String       @id @default(cuid())
  reportName   String       @db.NVarChar(200)
  submitterId  String
  submitter    User         @relation("ReportSubmitter", fields: [submitterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  onBehalfOfId String?
  paidToId     String
  paidTo       User         @relation("ReportPayee", fields: [paidToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  periodFrom   DateTime
  periodTo     DateTime
  status       ReportStatus @default(DRAFT)
  totalAmount  Decimal      @db.Decimal(12, 2)
  submittedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  changeLogs ReportChangeLog[]
}

/// Key-value store for admin-managed system settings (app version, announcement
/// banner message, …). Read on app load and cached client-side.
model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique @db.NVarChar(100)
  value     String   @db.NVarChar(Max)
  updatedAt DateTime @updatedAt
}

/// Audit trail: one row per change to a report after it has been submitted.
model ReportChangeLog {
  id          String           @id @default(cuid())
  reportId    String
  report      ExpenseReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  changedById String
  changedBy   User             @relation("ChangeAuthor", fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  changedAt   DateTime         @default(now())
  changeType  ReportChangeType
  field       String?          @db.NVarChar(100)
  oldValue    String?          @db.NVarChar(Max)
  newValue    String?          @db.NVarChar(Max)
  summary     String           @db.NVarChar(500)
  // Optional free-text detail (e.g. the approver's reason on a "send back").
  note        String?          @db.NVarChar(Max)

  @@index([reportId, changedAt])
  @@index([changedById])
}
